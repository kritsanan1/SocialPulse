
# SocialAI Pro - Environment Configuration Template
# Copy this file to .env and update with your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Primary database connection URL for Neon PostgreSQL
# Format: postgresql://username:password@hostname:5432/database_name
# Example: postgresql://myuser:mypassword@ep-cool-darkness-123456.us-east-1.aws.neon.tech/socialai_db
DATABASE_URL="postgresql://username:password@hostname:5432/database"

# Prisma-specific database URLs (for Neon compatibility)
POSTGRES_PRISMA_URL="postgresql://username:password@hostname:5432/database"
POSTGRES_URL_NON_POOLING="postgresql://username:password@hostname:5432/database"

# =============================================================================
# AUTHENTICATION & SESSION MANAGEMENT
# =============================================================================

# Replit database URL for session storage
# Obtain from Replit dashboard under "Secrets" tab
REPLIT_DB_URL="your_replit_database_url_here"

# Session secret for encryption (REQUIRED - must be 32+ characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: Changing this will invalidate all existing sessions
SESSION_SECRET="your_super_secure_session_secret_key_minimum_32_characters_long"

# =============================================================================
# SOCIAL MEDIA API INTEGRATION
# =============================================================================

# Ayrshare API key for cross-platform social media posting
# Sign up at: https://ayrshare.com/
# Supports: Twitter, Facebook, Instagram, LinkedIn, TikTok, Pinterest, Snapchat
AYRSHARE_API_KEY="ayr_live_your_api_key_here"

# Optional: Ayrshare profile key for multi-user management
# Used for team accounts and profile separation
AYRSHARE_PROFILE_KEY="your_profile_key_here"

# =============================================================================
# PAYMENT PROCESSING (STRIPE)
# =============================================================================

# Stripe secret key for payment processing
# Test: sk_test_... | Live: sk_live_...
# Obtain from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key_here"

# Stripe publishable key (safe to expose in frontend)
# Test: pk_test_... | Live: pk_live_...
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key_here"

# Stripe webhook endpoint secret for webhook verification
# Obtain from Stripe webhook configuration
# Format: whsec_...
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret_here"

# Stripe subscription price IDs
# Configure these in your Stripe dashboard
STRIPE_PRICE_ID_BASIC="price_basic_plan_id"
STRIPE_PRICE_ID_PRO="price_pro_plan_id"
STRIPE_PRICE_ID_ENTERPRISE="price_enterprise_plan_id"

# =============================================================================
# AI SERVICES (OPTIONAL)
# =============================================================================

# OpenAI API key for AI content generation features
# Sign up at: https://platform.openai.com/
# Used for: content suggestions, sentiment analysis, auto-generation
OPENAI_API_KEY="sk-your_openai_api_key_here"

# OpenAI organization ID (optional)
OPENAI_ORG_ID="org-your_organization_id"

# OpenAI model configuration
OPENAI_MODEL="gpt-4o-mini"
OPENAI_MAX_TOKENS="1000"

# =============================================================================
# PERFORMANCE MONITORING
# =============================================================================

# Google PageSpeed Insights API key
# Enable at: https://console.developers.google.com/
# Used for: Core Web Vitals monitoring, performance analytics
GOOGLE_PAGESPEED_API_KEY="AIzaSyYour_PageSpeed_API_Key_Here"

# Google Analytics measurement ID (optional)
GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Node.js environment
# Values: development | production | test
NODE_ENV="development"

# Application port (default: 5000 for Replit compatibility)
# Replit forwards port 5000 to public URLs
PORT="5000"

# Application base URL (used for webhooks and redirects)
# Development: http://localhost:5000
# Production: https://your-app-name.replit.app
APP_BASE_URL="http://localhost:5000"

# API base URL (for frontend requests)
# Should match APP_BASE_URL + /api
API_BASE_URL="http://localhost:5000/api"

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable specific features
ENABLE_AI_FEATURES="true"
ENABLE_PAYMENT_FEATURES="true"
ENABLE_ANALYTICS_FEATURES="true"
ENABLE_TEAM_FEATURES="true"

# Debug mode (enables additional logging)
DEBUG_MODE="false"

# =============================================================================
# RATE LIMITING & SECURITY
# =============================================================================

# Rate limiting configuration
RATE_LIMIT_WINDOW_MS="900000"        # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS="100"        # Maximum requests per window

# CORS configuration
CORS_ORIGIN="http://localhost:5000"   # Frontend origin
CORS_CREDENTIALS="true"              # Allow credentials

# =============================================================================
# LOGGING & MONITORING
# =============================================================================

# Log level configuration
# Values: error | warn | info | debug
LOG_LEVEL="info"

# Enable request logging
ENABLE_REQUEST_LOGGING="true"

# Sentry DSN for error tracking (optional)
SENTRY_DSN="https://your_sentry_dsn@sentry.io/project_id"

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================

# Redis URL for caching (optional)
# If not provided, in-memory caching will be used
REDIS_URL="redis://localhost:6379"

# Cache TTL in seconds
CACHE_TTL="3600"                     # 1 hour

# =============================================================================
# EMAIL CONFIGURATION (OPTIONAL)
# =============================================================================

# SMTP configuration for email notifications
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"
SMTP_FROM="noreply@yourapp.com"

# =============================================================================
# DEVELOPMENT-SPECIFIC SETTINGS
# =============================================================================

# Disable SSL in development
DISABLE_SSL="true"

# Enable hot reload for development
HOT_RELOAD="true"

# Mock external APIs in development
MOCK_EXTERNAL_APIS="false"

# =============================================================================
# SECURITY CONSIDERATIONS
# =============================================================================

# IMPORTANT SECURITY NOTES:
# 1. Never commit .env files to version control
# 2. Use strong, unique passwords and API keys
# 3. Rotate secrets regularly
# 4. Use different credentials for development and production
# 5. Enable 2FA on all external service accounts
# 6. Monitor API usage and set up alerts for unusual activity
# 7. Use environment-specific secrets management in production

# BACKUP RECOMMENDATIONS:
# 1. Store production secrets in Replit Secrets tab
# 2. Maintain secure backup of all credentials
# 3. Document credential rotation procedures
# 4. Set up monitoring for expired certificates/keys

# =============================================================================
# VALIDATION CHECKLIST
# =============================================================================

# Before deploying, ensure:
# ✅ All required environment variables are set
# ✅ Database connection is working
# ✅ API keys are valid and have proper permissions
# ✅ Webhook endpoints are accessible
# ✅ SSL certificates are valid (production)
# ✅ Rate limiting is configured appropriately
# ✅ Monitoring and logging are enabled
# ✅ Backup procedures are in place
